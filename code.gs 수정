// 쿼리 처리 (정직함 모드)
function processQuery(userQuery) {
  try {
    const query = userQuery.toLowerCase();
    
    // 매출 관련 질의
    if (query.includes('매출') || query.includes('revenue') || query.includes('sales')) {
      return getSalesData(query);
    }
    
    // 예산 관련 질의
    if (query.includes('예산') || query.includes('budget')) {
      return getBudgetData(query);
    }
    
    // 비용 관련 질의
    if (query.includes('비용') || query.includes('cost') || query.includes('expense')) {
      return getExpenseData(query);
    }
    
    // 거래처 관련 질의
    if (query.includes('거래처') || query.includes('고객') || query.includes('customer')) {
      return getCustomerData(query);
    }
    
    // 그래프 요청
    if (query.includes('그래프') || query.includes('차트') || query.includes('추이')) {
      return getChartData(query);
    }
    
    // 기본 응답
    return {
      type: 'text',
      message: '죄송합니다. 해당 질문에 대한 데이터를 찾을 수 없습니다.<br><br>' +
               '💡 <strong>가능한 질문 예시:</strong><br>' +
               '• "이번 달 매출 현황"<br>' +
               '• "부서별 예산 집행률"<br>' +
               '• "최근 3개월 비용 추이"<br>' +
               '• "상위 10개 거래처"<br><br>' +
               '<em>정직함 모드: 확실한 데이터만 제공합니다.</em>'
    };
    
  } catch (error) {
    return {
      type: 'text',
      message: '❌ 처리 중 오류가 발생했습니다: ' + error.message
    };
  }
}

