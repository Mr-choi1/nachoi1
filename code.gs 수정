// DB 스프레드시트 초기 설정 함수 (최초 1회 실행)
function setupDatabase() {
  const ss = SpreadsheetApp.create('SB_ERP_Database');
  
  // 매출 시트
  const salesSheet = ss.getSheetByName('시트1');
  salesSheet.setName('매출데이터');
  salesSheet.getRange('A1:E1').setValues([['날짜', '부서', '제품', '수량', '금액']]);
  salesSheet.getRange('A1:E1').setFontWeight('bold').setBackground('#0080FF').setFontColor('#FFFFFF');
  
  // 예산 시트
  const budgetSheet = ss.insertSheet('예산데이터');
  budgetSheet.getRange('A1:D1').setValues([['부서', '예산', '집행액', '집행률']]);
  budgetSheet.getRange('A1:D1').setFontWeight('bold').setBackground('#0080FF').setFontColor('#FFFFFF');
  
  // 비용 시트
  const expenseSheet = ss.insertSheet('비용데이터');
  expenseSheet.getRange('A1:D1').setValues([['날짜', '항목', '금액', '담당자']]);
  expenseSheet.getRange('A1:D1').setFontWeight('bold').setBackground('#0080FF').setFontColor('#FFFFFF');
  
  // 거래처 시트
  const customerSheet = ss.insertSheet('거래처데이터');
  customerSheet.getRange('A1:D1').setValues([['거래처명', '담당자', '연락처', '거래액']]);
  customerSheet.getRange('A1:D1').setFontWeight('bold').setBackground('#0080FF').setFontColor('#FFFFFF');
  
  Logger.log('데이터베이스 생성 완료: ' + ss.getUrl());
  Logger.log('스프레드시트 ID: ' + ss.getId());
  
  return ss.getId();
}
