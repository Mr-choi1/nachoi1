// 쿼리 전처리 및 오타 보정
function preprocessQuery(userQuery) {
  let processedQuery = userQuery.toLowerCase().trim();
  
  // 1. 공백 정규화
  processedQuery = processedQuery.replace(/\s+/g, ' ');
  
  // 2. 키워드 사전을 통한 오타 보정
  for (const [standard, variants] of Object.entries(KEYWORD_DICTIONARY)) {
    for (const variant of variants) {
      const regex = new RegExp(variant, 'gi');
      if (processedQuery.match(regex)) {
        processedQuery = processedQuery.replace(regex, standard);
      }
    }
  }
  
  return processedQuery;
}

// 유사도 계산 (레벤슈타인 거리)
function calculateSimilarity(str1, str2) {
  const len1 = str1.length;
  const len2 = str2.length;
  const matrix = [];

  for (let i = 0; i <= len1; i++) {
    matrix[i] = [i];
  }

  for (let j = 0; j <= len2; j++) {
    matrix[0][j] = j;
  }

  for (let i = 1; i <= len1; i++) {
    for (let j = 1; j <= len2; j++) {
      if (str1.charAt(i - 1) === str2.charAt(j - 1)) {
        matrix[i][j] = matrix[i - 1][j - 1];
      } else {
        matrix[i][j] = Math.min(
          matrix[i - 1][j - 1] + 1,
          matrix[i][j - 1] + 1,
          matrix[i - 1][j] + 1
        );
      }
    }
  }

  const distance = matrix[len1][len2];
  const maxLen = Math.max(len1, len2);
  return maxLen === 0 ? 1 : 1 - distance / maxLen;
}

// 키워드 포함 여부 확인 (유연한 매칭)
function containsKeyword(query, keywords) {
  const queryLower = query.toLowerCase();
  
  for (const keyword of keywords) {
    // 정확한 매칭
    if (queryLower.includes(keyword.toLowerCase())) {
      return true;
    }
    
    // 유사도 매칭 (70% 이상)
    const words = queryLower.split(' ');
    for (const word of words) {
      if (calculateSimilarity(word, keyword.toLowerCase()) >= 0.7) {
        return true;
      }
    }
  }
  
  return false;
}

// 쿼리 처리 (오타 보정 포함)
function processQuery(userQuery) {
  try {
    // 쿼리 전처리 및 오타 보정
    const processedQuery = preprocessQuery(userQuery);
    
    Logger.log('원본 쿼리: ' + userQuery);
    Logger.log('보정된 쿼리: ' + processedQuery);
    
    // 매출 관련 질의
    if (containsKeyword(processedQuery, ['매출', 'revenue', 'sales', '판매'])) {
      return getSalesData(processedQuery, userQuery);
    }
    
    // 예산 관련 질의
    if (containsKeyword(processedQuery, ['예산', 'budget', '집행'])) {
      return getBudgetData(processedQuery, userQuery);
    }
    
    // 비용 관련 질의
    if (containsKeyword(processedQuery, ['비용', 'cost', 'expense', '경비', '지출'])) {
      return getExpenseData(processedQuery, userQuery);
    }
    
    // 거래처 관련 질의
    if (containsKeyword(processedQuery, ['거래처', '고객', 'customer', 'client', '업체'])) {
      return getCustomerData(processedQuery, userQuery);
    }
    
    // 그래프 요청
    if (containsKeyword(processedQuery, ['그래프', 'graph', 'chart', '차트', '추이', 'trend'])) {
      return getChartData(processedQuery, userQuery);
    }
    
    // 부서 관련 질의
    if (containsKeyword(processedQuery, ['부서', 'department', '팀'])) {
      return getDepartmentData(processedQuery, userQuery);
    }
        // 키워드 매칭 실패 시 포텐스닷 LLM에게 자유 질의로 위임
    try {
      const aiAnswer = callPotensAI(userQuery);
      return {
        type: 'text',
        message: '🤖 ' + aiAnswer +
                 '<br><br><small style="color:#666;">※ ERP 정형 데이터가 아닌 AI 자유 응답입니다.</small>'
      };
    } catch (aiError) {
      Logger.log('Potens AI 호출 실패: ' + aiError.message);
    }

    // 키워드 기반 추천
    const suggestions = getSuggestions(processedQuery);
    
    return {
      type: 'text',
      message: '🤔 질문을 정확히 이해하지 못했습니다.<br><br>' +
               (suggestions.length > 0 ? 
                 '<strong>혹시 이런 질문을 하신 건가요?</strong><br>' + 
                 suggestions.map(s => `• "${s}"`).join('<br>') + '<br><br>' : '') +
               '💡 <strong>가능한 질문 예시:</strong><br>' +
               '• "이번 달 매출 현황"<br>' +
               '• "부서별 예산 집행률"<br>' +
               '• "최근 3개월 비용 추이"<br>' +
               '• "상위 10개 거래처"<br><br>' +
               '<em>정직함 모드: 확실한 데이터만 제공합니다.</em>'
    };
    
  } catch (error) {
    Logger.log('에러 발생: ' + error.message);
    return {
      type: 'text',
      message: '❌ 처리 중 오류가 발생했습니다.<br><br>' +
               '다시 한 번 질문해주시거나, 다른 표현으로 말씀해주세요.'
    };
  }
}

// 질문 추천 생성
function getSuggestions(query) {
  const suggestions = [];
  const queryWords = query.toLowerCase().split(' ');
  
  const templates = [
    '이번 달 매출 현황을 보여줘',
    '부서별 예산 집행률을 표로 정리해줘',
    '최근 3개월 비용 추이를 그래프로 보여줘',
    '상위 10개 거래처 목록을 알려줘',
    '영업팀 예산 현황을 알려줘'
  ];
  
  for (const template of templates) {
    for (const word of queryWords) {
      if (word.length >= 2 && template.includes(word)) {
        suggestions.push(template);
        break;
      }
    }
    if (suggestions.length >= 3) break;
  }
  
  return suggestions;
}

